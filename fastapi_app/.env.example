# ============================================
# Supabase Configuration (Optional)
# ============================================
# For JWT authentication and user data management
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# TTS Configuration
# ============================================
# Enable local TTS (0=disabled, 1=enabled)
# qwen 模式会在后端启动时拉起本地 vLLM-Omni 服务并等待 ready
USE_LOCAL_TTS=1

# TTS engine: qwen (vLLM-Omni, recommended) or firered (legacy local fallback)
TTS_ENGINE=qwen

# Local TTS server
LOCAL_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
LOCAL_TTS_PORT=26211
LOCAL_TTS_CMD=vllm-omni
LOCAL_TTS_CUDA_VISIBLE_DEVICES=6
LOCAL_TTS_GPU_MEMORY_UTILIZATION=0.3
# Optional: VLLM_OMNI_STAGE_CONFIG=/path/to/qwen3_tts.yaml

# Auto-unload timeout in seconds (default: 300 = 5 minutes)
TTS_IDLE_TIMEOUT=300

# ============================================
# Local Embedding via vLLM
# ============================================
USE_LOCAL_EMBEDDING=1
LOCAL_EMBEDDING_MODEL=Octen/Octen-Embedding-0.6B
LOCAL_EMBEDDING_PORT=26210
LOCAL_EMBEDDING_CMD=vllm
LOCAL_EMBEDDING_CUDA_VISIBLE_DEVICES=5
LOCAL_EMBEDDING_GPU_MEMORY_UTILIZATION=0.3

# Optional vLLM settings
# VLLM_GPU_MEMORY_UTILIZATION=0.45

# ============================================
# LLM API Configuration
# ============================================
DEFAULT_LLM_API_URL=http://your-llm-api-url/v1/

# ============================================
# Knowledge Base Configuration
# ============================================
KB_CHAT_MODEL=deepseek-v3.2
